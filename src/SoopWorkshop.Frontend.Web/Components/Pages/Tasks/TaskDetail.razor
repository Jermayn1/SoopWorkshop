@page "/tasks/{Id:guid}"

<PageTitle>@(_task?.Title ?? "Aufgabe") - SoopWorkshop</PageTitle>

@if (_isLoading)
{
    <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
}
else if (_task is null)
{
    <MudAlert Severity="Severity.Error">Aufgabe nicht gefunden.</MudAlert>
}
else
{
    <MudStack Spacing="4">

        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudText Typo="Typo.h4">@_task.Title</MudText>
            <MudChip T="string" Color="@GetDifficultyColor()" Size="Size.Small">
                @_task.Difficulty.ToString()
            </MudChip>
        </MudStack>

        <MudPaper Elevation="2" Class="pa-4">
            <MudText Typo="Typo.body1" Style="white-space: pre-wrap;">
                @_task.Description
            </MudText>
        </MudPaper>

        @if (_task.Hints.Count > 0)
        {
            <MudExpansionPanels>
                <MudExpansionPanel>
                    <TitleContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Lightbulb" Color="Color.Warning" />
                            <MudText Typo="Typo.subtitle1">Tipps & Hilfestellungen</MudText>
                        </MudStack>
                    </TitleContent>
                    <ChildContent>
                        <MudList T="string">
                            @foreach (var hint in _task.Hints)
                            {
                                <MudListItem T="string" Icon="@Icons.Material.Filled.ChevronRight">
                                    @hint.Content
                                </MudListItem>
                            }
                        </MudList>
                    </ChildContent>
                </MudExpansionPanel>
            </MudExpansionPanels>
        }

        <MudPaper Elevation="2" Class="pa-4">
            <MudText Typo="Typo.h6" GutterBottom="true">Lösung abgeben</MudText>

            <MudFileUpload T="IReadOnlyList<IBrowserFile>"
                           Accept=".java"
                           OnFilesChanged="OnFilesChanged">
                <ActivatorContent>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.UploadFile">
                        .java Dateien auswaehlen
                    </MudButton>
                </ActivatorContent>
            </MudFileUpload>

            @if (_selectedFiles.Count > 0)
            {
                <MudList T="string" Class="mt-2">
                    @foreach (var file in _selectedFiles)
                    {
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Code">
                            @file.Name
                        </MudListItem>
                    }
                </MudList>
            }

            @if (_errorMessage is not null)
            {
                <MudAlert Severity="Severity.Error" Class="mt-2">@_errorMessage</MudAlert>
            }

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Send"
                       OnClick="SubmitAsync"
                       Disabled="@(_selectedFiles.Count == 0 || _isSubmitting)"
                       Class="mt-4">
                @if (_isSubmitting)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Wird eingereicht...</span>
                }
                else
                {
                    <span>Jetzt pruefen</span>
                }
            </MudButton>

        </MudPaper>

    </MudStack>
}